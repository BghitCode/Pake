{
    "productName": "Lurk",
    "identifier": "com.bghitapp.aaa304b",
    "version": "1.0.0",
    "app": {
        "withGlobalTauri": true,
        "security": {
            "headers": {},
            "csp": null
        }
    },
    "build": {
        "frontendDist": "../dist"
    },
    "bundle": {
        "icon": [
            "png/lurk_256.ico"
        ],
        "active": true,
        "resources": [
            "png/lurk_256.ico"
        ],
        "targets": [
            "msi"
        ],
        "windows": {
            "digestAlgorithm": "sha256",
            "wix": {
                "language": [
                    "en-US"
                ],
                "template": "assets/main.wxs"
            }
        }
    },
    "mainBinaryName": "bghitapp-lurk"
}
